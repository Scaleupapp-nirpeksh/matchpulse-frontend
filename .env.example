# MatchPulse Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API URL (EC2 backend)
NEXT_PUBLIC_API_URL=https://api.mtchpulse.com

# WebSocket URL (same as API for Socket.io)
NEXT_PUBLIC_SOCKET_URL=https://api.mtchpulse.com

# VAPID Public Key for Push Notifications (from backend .env)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# App URL (for metadata/OG tags)
NEXT_PUBLIC_APP_URL=https://mtchpulse.com
